# One Inference API key powers BOTH the agent's model calls and tracing.
# Get one at https://inference.net/dashboard/api-keys
INFERENCE_API_KEY=

# Any tool-capable model from https://inference.net. Defaults to gpt-4.1-mini.
MODEL_ID=gpt-4.1-mini

# Optional — real web search via Tavily. Leave blank and run with --mock-search instead.
# Free tier (no credit card) at https://tavily.com
TAVILY_API_KEY=

# Optional overrides — the defaults are correct for inference.net.
# INFERENCE_BASE_URL=https://api.inference.net/v1
# CATALYST_OTLP_ENDPOINT=https://telemetry.inference.net
# CATALYST_SERVICE_NAME=halo-search-agent-example
